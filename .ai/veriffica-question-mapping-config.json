{
  "version": 1,
  "name": "veriffica-question-mapping-config",
  "description": "Implementation-ready question visibility config for Veriffica MVP",
  "part1": {
    "requiredFields": [
      "make",
      "model",
      "year",
      "registrationNumber",
      "fuelType",
      "transmission",
      "drive",
      "bodyType"
    ],
    "enumValues": {
      "fuelType": ["petrol", "diesel", "lpg", "hybrid", "electric"],
      "transmission": ["manual", "automatic"],
      "drive": ["2wd", "4wd"],
      "bodyType": [
        "sedan",
        "hatchback",
        "suv",
        "coupe",
        "convertible",
        "van",
        "pickup",
        "other"
      ]
    }
  },
  "runtimeFlags": {
    "requiredPart1Complete": {
      "type": "derived",
      "description": "All required Part 1 fields are present and valid"
    },
    "combustionEnginePresent": {
      "type": "derived",
      "description": "True for petrol, diesel, LPG and most hybrid vehicles"
    },
    "sparkPlugsPresent": {
      "type": "runtime-confirmed",
      "description": "Used mainly for hybrid edge cases"
    },
    "chargingPortEquipped": {
      "type": "runtime-confirmed",
      "description": "True when the inspected vehicle has a usable charging port and charging equipment should be checked"
    },
    "turboEquipped": {
      "type": "runtime-confirmed",
      "description": "True when the inspected combustion vehicle has a turbocharger"
    },
    "mechanicalCompressorEquipped": {
      "type": "runtime-confirmed",
      "description": "True when the inspected combustion vehicle has a belt-driven mechanical compressor"
    },
    "evBatteryDocsAvailable": {
      "type": "runtime-confirmed",
      "description": "True when the seller provides battery or charging-related documents worth checking"
    }
  },
  "questionGroups": [
    {
      "id": "p2_car_body",
      "part": "part2",
      "label": "Car Body",
      "dependsOnFields": [],
