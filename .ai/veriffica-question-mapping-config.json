  "derivedRules": [
    {
      "id": "R1",
      "name": "gate-parts-by-part1-validity",
      "description": "Lock Parts 2-5 until all required Part 1 fields are valid"
    },
    {
      "id": "R2",
      "name": "update-session-title-live",
      "description": "Update the inspection tile immediately after make, model, year or registration number changes"
    },
    {
      "id": "R3",
      "name": "prune-hidden-group-answers",
      "description": "When any mapping field changes, remove answers belonging to question groups that became hidden"
    },
    {
